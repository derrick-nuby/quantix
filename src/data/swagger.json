{
  "openapi": "3.0.0",
  "info": {
    "title": "Quantix API",
    "description": "API for Quantix: A Storage and Stock Management System",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Products",
      "description": "Operations related to product management"
    },
    {
      "name": "Daily Stock",
      "description": "Operations related to daily stock management"
    },
    {
      "name": "Daily Summary",
      "description": "Operations related to daily summaries and reports"
    },
    {
      "name": "Cron Jobs",
      "description": "Automated tasks for system maintenance"
    }
  ],
  "paths": {
    "/api/products": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get all products",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term for product name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Field to sort by",
            "required": false,
            "schema": {
              "type": "string",
              "default": "productNumber"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order (asc or desc)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "currentPage": {
                          "type": "integer"
                        },
                        "totalPages": {
                          "type": "integer"
                        },
                        "totalCount": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Create a new product",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/products/bulk": {
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Create multiple products in bulk",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "products": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/CreateProductDto"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Products created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get a product by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "patch": {
        "tags": [
          "Products"
        ],
        "summary": "Update a product",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProductDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Products"
        ],
        "summary": "Delete a product",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted successfully"
          },
          "400": {
            "description": "Cannot delete product with existing stock entries"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/start-day": {
      "post": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Start a new day by creating daily stock entries",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Daily stock entries created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyStock"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data or previous day's entries not complete"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}": {
      "get": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Get daily stock entries for a specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of daily stock entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyStock"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No daily stocks found for the given date"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/hashes": {
      "get": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Get edit hashes for daily stock entries on a specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of edit hashes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hashes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No hashes found for the given date"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/lock": {
      "post": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Lock daily stock entries for a specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily entries locked successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "dailySummary": {
                      "$ref": "#/components/schemas/DailySummary"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/unlock": {
      "post": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Unlock daily stock entries for a specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "editHash": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Daily entries unlocked successfully"
          },
          "400": {
            "description": "Invalid edit hash"
          },
          "404": {
            "description": "Daily summary not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/summary": {
      "get": {
        "tags": [
          "Daily Summary"
        ],
        "summary": "Get or create a daily summary for a specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailySummary"
                }
              }
            }
          },
          "404": {
            "description": "No daily stocks found for the given date"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/{productId}": {
      "patch": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Update a daily stock entry for a specific product and date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDailyStockDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Daily stock entry updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyStock"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data or entry is locked"
          },
          "404": {
            "description": "Daily stock entry not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/daily-stock/{date}/load-previous-day": {
      "post": {
        "tags": [
          "Daily Stock"
        ],
        "summary": "Load previous day's data into the current day",
        "description": "This endpoint allows you to load the previous day's stock data into the current day. Useful when updates are made to the previous day's entries and need to be reflected in the current day.",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "The current date for which to load the previous day's data (in ISO 8601 format, e.g., '2023-10-23').",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Previous day's data loaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyStock"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or no previous day data found"
          },
          "404": {
            "description": "No entries found for the previous day"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cron/lock-previous-day": {
      "get": {
        "tags": [
          "Cron Jobs"
        ],
        "summary": "Lock the previous day's stock entries",
        "responses": {
          "200": {
            "description": "Previous day locked successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "productNumber": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "lowStock": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "productNumber": {
            "type": "integer"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          }
        }
      },
      "DailyStock": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "productId": {
            "type": "string"
          },
          "openingStock": {
            "type": "integer"
          },
          "closingStock": {
            "type": "integer"
          },
          "soldQuantity": {
            "type": "integer"
          },
          "newStock": {
            "type": "integer"
          },
          "buyingPrice": {
            "type": "number",
            "format": "decimal"
          },
          "sellingPrice": {
            "type": "number",
            "format": "decimal"
          },
          "isLocked": {
            "type": "boolean"
          },
          "editHash": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateDailyStockDto": {
        "type": "object",
        "properties": {
          "soldQuantity": {
            "type": "integer"
          },
          "newStock": {
            "type": "integer"
          },
          "buyingPrice": {
            "type": "number",
            "format": "decimal"
          },
          "sellingPrice": {
            "type": "number",
            "format": "decimal"
          }
        }
      },
      "DailySummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "totalProfit": {
            "type": "number",
            "format": "decimal"
          },
          "totalInflow": {
            "type": "number",
            "format": "decimal"
          },
          "totalOutflow": {
            "type": "number",
            "format": "decimal"
          },
          "isLocked": {
            "type": "boolean"
          },
          "editHash": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}